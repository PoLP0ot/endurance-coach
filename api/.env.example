# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret      # Settings > API > JWT Secret (HS256)
SUPABASE_JWKS_URL=                        # Optional: for RS256 verification

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql+psycopg2://postgres:password@db.your-project.supabase.co:5432/postgres

# AI
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL_CHAT=claude-sonnet-4-6
LLM_MODEL_PLAN=claude-opus-4-8

# Queue
REDIS_URL=redis://localhost:6379

# Email
RESEND_API_KEY=re_...

# Payments
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Security
ENCRYPTION_KEY=                           # Fernet key for encrypting Garmin tokens at rest

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
